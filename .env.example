# Environment variables for Qwen3-TTS Multi-GPU Service
# Copy this file to .env and customize as needed

# Optional: Hugging Face Hub token for authenticated model downloads
# Obtain from https://huggingface.co/settings/tokens
HUGGINGFACE_HUB_TOKEN=

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================================
# Model Directories
# ============================================================================
MODEL_CACHE_DIR=/models
OUTPUT_DIR=/workspace/outputs

# ============================================================================
# GPU Configuration
# ============================================================================
# Comma-separated list of GPU IDs to use for TTS
TTS_GPUS=0,1,2,3

# Minimum free GPU memory (MB) required before starting job
GPU_MEMORY_THRESHOLD_MB=1024

# Whisper transcription GPU pool (typically same as TTS GPUs)
WHISPER_DEVICE_POOL=0,1,2,3

# ============================================================================
# Model Variants
# ============================================================================
# Enable/disable specific model variants (true/false)
ENABLE_BASE_MODEL=true
ENABLE_CUSTOM_VOICE=true
ENABLE_VOICE_DESIGN=true

# Model precision (bfloat16 or float16)
DEFAULT_DTYPE=bfloat16

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
GRADIO_PORT=7860

# ============================================================================
# Whisper Configuration
# ============================================================================
# Whisper model (HuggingFace repo id preferred). Shorthand also supported.
# Examples:
# - openai/whisper-large-v3-turbo
# - large-v3-turbo
WHISPER_MODEL=openai/whisper-large-v3-turbo
# Local path to a pre-downloaded Whisper model in the `stt_models` volume.
# If present, the service will prefer this local path over downloading from HF.
WHISPER_MODEL_PATH=/stt_models/whisper-large-v3-turbo

# ============================================================================
# Job Processing Limits
# ============================================================================
# Maximum text length (characters)
MAX_TEXT_LENGTH=5000

# Preferred maximum characters per TTS chunk (split on sentence boundaries)
# Single sentences longer than this will be returned whole.
TTS_CHUNK_MAX_CHARS=1000

# Maximum number of candidates per job
MAX_CANDIDATES=10

# Default number of candidates if not specified
DEFAULT_CANDIDATES=1

# Job timeout (seconds)
JOB_TIMEOUT=3600

# ============================================================================
# Cleanup and Retention
# ============================================================================
# Output file retention period (hours)
RETENTION_HOURS=24

# Cleanup schedule (24-hour format, e.g., "0:00" for midnight)
CLEANUP_SCHEDULE=0:00

# ============================================================================
# Logging
# ============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable structured JSON logging (true/false)
STRUCTURED_LOGGING=true
